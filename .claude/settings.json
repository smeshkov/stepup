{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "edit .github/*",
      "edit cmd/*",
      "edit internal/*",
      "edit Makefile",
      "edit CLAUDE.md",
      "edit ARCHITECTURE.md",
      "Bash(go:*)",
      "Bash(go run *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make fmt)",
      "Bash(make checkfmt)",
      "Bash(make vet)"
    ],
    "deny": [
      "edit _docs/*",
      "rm -rf *"
    ]
  }
}